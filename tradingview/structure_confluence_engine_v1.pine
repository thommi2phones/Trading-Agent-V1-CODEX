//@version=5
indicator("TA Codex - Structure Confluence Engine v1", overlay=true, max_labels_count=500)

// ============================================
// USER-DRAWN STRUCTURE (PATTERN + LEVEL) MODEL
// ============================================
// Note: Complex pattern recognition (HnS/CnH/flags) is visual-first in your workflow.
// This script focuses on objective confirmation data for your external agent.

// -------------------------
// Inputs: Thanos EMA Cluster
// -------------------------
emaFastLen = input.int(8, "EMA Fast", minval=1)
emaMid1Len = input.int(21, "EMA Mid 1", minval=1)
emaMid2Len = input.int(34, "EMA Mid 2", minval=1)
emaSlowLen = input.int(55, "EMA Slow", minval=1)
compressionAtrMult = input.float(0.20, "EMA Compression ATR Mult", minval=0.01, step=0.01)

emaFast = ta.ema(close, emaFastLen)
emaMid1 = ta.ema(close, emaMid1Len)
emaMid2 = ta.ema(close, emaMid2Len)
emaSlow = ta.ema(close, emaSlowLen)
atr14 = ta.atr(14)

emaBullStack = emaFast > emaMid1 and emaMid1 > emaMid2 and emaMid2 > emaSlow
emaBearStack = emaFast < emaMid1 and emaMid1 < emaMid2 and emaMid2 < emaSlow
emaCompressed = math.abs(emaFast - emaMid2) <= atr14 * compressionAtrMult

plot(emaFast, "EMA Fast", color=color.new(color.white, 0), linewidth=1)
plot(emaMid1, "EMA Mid 1", color=color.new(color.yellow, 0), linewidth=1)
plot(emaMid2, "EMA Mid 2", color=color.new(color.orange, 0), linewidth=1)
plot(emaSlow, "EMA Slow", color=color.new(color.red, 0), linewidth=1)

// -------------------------
// Inputs: RSI (structure use)
// -------------------------
rsiLen = input.int(14, "RSI Length", minval=2)
rsi = ta.rsi(close, rsiLen)
rsiBullRegime = rsi > 50
rsiBearRegime = rsi < 50
rsiCrossUp50 = ta.crossover(rsi, 50)
rsiCrossDown50 = ta.crossunder(rsi, 50)

// -------------------------
// Inputs: MACD Histogram
// -------------------------
macdFast = input.int(12, "MACD Fast", minval=1)
macdSlow = input.int(26, "MACD Slow", minval=1)
macdSignal = input.int(9, "MACD Signal", minval=1)
[macdLine, signalLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdBullExpand = macdHist > 0 and macdHist > macdHist[1]
macdBearExpand = macdHist < 0 and macdHist < macdHist[1]

// -------------------------
// Inputs: TTM-style squeeze
// -------------------------
sqzLen = input.int(20, "Squeeze Length", minval=5)
bbMult = input.float(2.0, "BB Mult", minval=0.1, step=0.1)
kcMult = input.float(1.5, "KC Mult", minval=0.1, step=0.1)

basis = ta.sma(close, sqzLen)
dev = ta.stdev(close, sqzLen) * bbMult
bbUpper = basis + dev
bbLower = basis - dev
kcUpper = basis + ta.atr(sqzLen) * kcMult
kcLower = basis - ta.atr(sqzLen) * kcMult

squeezeOn = bbUpper < kcUpper and bbLower > kcLower
squeezeRelease = not squeezeOn and squeezeOn[1]

// -------------------------
// Inputs: Historical key level proxy (blue dashed)
// -------------------------
levelLookback = input.int(80, "Historical Level Lookback", minval=20)
levelToleranceAtr = input.float(0.15, "Level Touch ATR Tolerance", minval=0.01, step=0.01)

priorRangeHigh = ta.highest(high, levelLookback)
priorRangeLow = ta.lowest(low, levelLookback)
levelTol = atr14 * levelToleranceAtr

atHighLevel = math.abs(close - priorRangeHigh) <= levelTol
atLowLevel = math.abs(close - priorRangeLow) <= levelTol
breakAboveLevel = close > priorRangeHigh[1]
breakBelowLevel = close < priorRangeLow[1]

plot(priorRangeHigh, "Proxy Key High", color=color.new(color.blue, 30), linewidth=1, style=plot.style_linebr)
plot(priorRangeLow, "Proxy Key Low", color=color.new(color.blue, 30), linewidth=1, style=plot.style_linebr)

// -------------------------
// Inputs: Manual Fib levels by significance color
// -------------------------
useManualFib = input.bool(true, "Use Manual Fib Levels")

fibW1 = input.float(0.0, "Fib White 1")
fibW2 = input.float(0.0, "Fib White 2")
fibW3 = input.float(0.0, "Fib White 3")

fibY1 = input.float(0.0, "Fib Yellow 1")
fibY2 = input.float(0.0, "Fib Yellow 2")
fibY3 = input.float(0.0, "Fib Yellow 3")

fibG1 = input.float(0.0, "Fib Green 1")
fibG2 = input.float(0.0, "Fib Green 2")
fibG3 = input.float(0.0, "Fib Green 3")

fibTolAtr = input.float(0.12, "Fib Proximity ATR Tolerance", minval=0.01, step=0.01)
fibTol = atr14 * fibTolAtr

f_isNearLevel(level) =>
    level > 0 and (math.abs(close - level) <= fibTol or math.abs(low - level) <= fibTol or math.abs(high - level) <= fibTol)

nearWhite = useManualFib and (f_isNearLevel(fibW1) or f_isNearLevel(fibW2) or f_isNearLevel(fibW3))
nearYellow = useManualFib and (f_isNearLevel(fibY1) or f_isNearLevel(fibY2) or f_isNearLevel(fibY3))
nearGreen = useManualFib and (f_isNearLevel(fibG1) or f_isNearLevel(fibG2) or f_isNearLevel(fibG3))

fibWeight = nearGreen ? 3 : nearYellow ? 2 : nearWhite ? 1 : 0
fibSignificance = nearGreen ? "GREEN" : nearYellow ? "YELLOW" : nearWhite ? "WHITE" : "NONE"

// -------------------------
// Inputs: Pattern bias handoff
// -------------------------
// Pattern is the #1 driver in your workflow and is visual/manual.
// Use this selector to encode current dominant pattern bias for the webhook.
patternBias = input.string("neutral", "Dominant Pattern Bias", options=["bullish", "bearish", "neutral"])
patternConfirmed = input.bool(false, "Pattern Confirmed (manual)")

// -------------------------
// Alert taxonomy (manual semantic tags)
// -------------------------
taxonomyVersion = input.string("tax_v1", "Taxonomy Version")
setupIdSuffix = input.string("001", "Setup ID Suffix")
setupId = syminfo.ticker + "_" + setupIdSuffix
patternType = input.string("flag", "Pattern Type", options=["flag", "pennant", "channel", "trendline", "hns", "inverse_hns", "cnh", "wedge", "arc", "other"])
setupStage = input.string("watch", "Setup Stage", options=["watch", "trigger", "in_trade", "tp_zone", "invalidated"])
timeHorizon = input.string("intraday", "Time Horizon", options=["scalp", "intraday", "swing"])

// -------------------------
// Manual trade levels (entry framework)
// -------------------------
useTradeLevels = input.bool(true, "Use Manual Trade Levels")
tradeDirection = input.string("long", "Trade Direction", options=["long", "short"])
entryPrice = input.float(0.0, "Entry Price")
stopPrice = input.float(0.0, "Stop Price")
tp1Price = input.float(0.0, "TP1 Price")
tp2Price = input.float(0.0, "TP2 Price")
tp3Price = input.float(0.0, "TP3 Price")
levelTolAtr = input.float(0.10, "Trade Level ATR Tolerance", minval=0.01, step=0.01)
levelTolTrade = atr14 * levelTolAtr

f_validLevel(level) =>
    level > 0

hasEntry = useTradeLevels and f_validLevel(entryPrice)
hasStop = useTradeLevels and f_validLevel(stopPrice)
hasTp1 = useTradeLevels and f_validLevel(tp1Price)
hasTp2 = useTradeLevels and f_validLevel(tp2Price)
hasTp3 = useTradeLevels and f_validLevel(tp3Price)

nearEntry = hasEntry and math.abs(close - entryPrice) <= levelTolTrade
nearStop = hasStop and math.abs(close - stopPrice) <= levelTolTrade
nearTp1 = hasTp1 and math.abs(close - tp1Price) <= levelTolTrade
nearTp2 = hasTp2 and math.abs(close - tp2Price) <= levelTolTrade
nearTp3 = hasTp3 and math.abs(close - tp3Price) <= levelTolTrade

// Wick-based hit (bar spans the level — may include wicks on volatile candles)
hitEntry = hasEntry and high >= entryPrice and low <= entryPrice
hitStop = hasStop and high >= stopPrice and low <= stopPrice
hitTp1 = hasTp1 and high >= tp1Price and low <= tp1Price
hitTp2 = hasTp2 and high >= tp2Price and low <= tp2Price
hitTp3 = hasTp3 and high >= tp3Price and low <= tp3Price

// Close-confirmed hit (stronger signal — price closed through the level)
hitEntryClose = hasEntry and math.abs(close - entryPrice) <= levelTolTrade
hitStopClose = hasStop and math.abs(close - stopPrice) <= levelTolTrade
hitTp1Close = hasTp1 and math.abs(close - tp1Price) <= levelTolTrade
hitTp2Close = hasTp2 and math.abs(close - tp2Price) <= levelTolTrade
hitTp3Close = hasTp3 and math.abs(close - tp3Price) <= levelTolTrade

distEntryAtr = hasEntry and atr14 > 0 ? math.abs(close - entryPrice) / atr14 : na
distStopAtr = hasStop and atr14 > 0 ? math.abs(close - stopPrice) / atr14 : na
distTp1Atr = hasTp1 and atr14 > 0 ? math.abs(close - tp1Price) / atr14 : na
distTp2Atr = hasTp2 and atr14 > 0 ? math.abs(close - tp2Price) / atr14 : na
distTp3Atr = hasTp3 and atr14 > 0 ? math.abs(close - tp3Price) / atr14 : na

risk = hasEntry and hasStop ? math.abs(entryPrice - stopPrice) : na
rrTp1 = hasTp1 and not na(risk) and risk > 0 ? math.abs(tp1Price - entryPrice) / risk : na
rrTp2 = hasTp2 and not na(risk) and risk > 0 ? math.abs(tp2Price - entryPrice) / risk : na
rrTp3 = hasTp3 and not na(risk) and risk > 0 ? math.abs(tp3Price - entryPrice) / risk : na

plot(hasEntry ? entryPrice : na, "Manual Entry", color=color.new(color.white, 0), linewidth=2, style=plot.style_linebr)
plot(hasStop ? stopPrice : na, "Manual Stop", color=color.new(color.red, 0), linewidth=2, style=plot.style_linebr)
plot(hasTp1 ? tp1Price : na, "Manual TP1", color=color.new(color.orange, 0), linewidth=2, style=plot.style_linebr)
plot(hasTp2 ? tp2Price : na, "Manual TP2", color=color.new(color.orange, 15), linewidth=2, style=plot.style_linebr)
plot(hasTp3 ? tp3Price : na, "Manual TP3", color=color.new(color.orange, 30), linewidth=2, style=plot.style_linebr)

// -------------------------
// SRChannel proxy (gut-check)
// -------------------------
srLen = input.int(50, "SRChannel Length", minval=10)
srUpper = ta.highest(high, srLen)
srLower = ta.lowest(low, srLen)
nearSrUpper = math.abs(close - srUpper) <= levelTol
nearSrLower = math.abs(close - srLower) <= levelTol
plot(srUpper, "SRChannel Upper", color=color.new(color.aqua, 60), linewidth=1)
plot(srLower, "SRChannel Lower", color=color.new(color.aqua, 60), linewidth=1)

// -------------------------
// Extra diagnostics (for validation + richer relay)
// -------------------------
barRange = high - low
barBody = math.abs(close - open)
bodyPctOfRange = barRange > 0 ? (barBody / barRange) * 100 : 0.0
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
upperWickPct = barRange > 0 ? (upperWick / barRange) * 100 : 0.0
lowerWickPct = barRange > 0 ? (lowerWick / barRange) * 100 : 0.0
rangeAtrRatio = atr14 > 0 ? barRange / atr14 : na

emaSpread = math.abs(emaFast - emaSlow)
emaSpreadAtr = atr14 > 0 ? emaSpread / atr14 : na
rsiSlope3 = rsi - rsi[3]
macdHistSlope3 = macdHist - macdHist[3]

distToEmaFastAtr = atr14 > 0 ? (close - emaFast) / atr14 : na
distToEmaSlowAtr = atr14 > 0 ? (close - emaSlow) / atr14 : na
distToHighLevelAtr = atr14 > 0 ? (close - priorRangeHigh) / atr14 : na
distToLowLevelAtr = atr14 > 0 ? (close - priorRangeLow) / atr14 : na

f_distAtr(level) =>
    not na(level) and atr14 > 0 ? math.abs(close - level) / atr14 : na

distFibW1Atr = f_distAtr(fibW1)
distFibW2Atr = f_distAtr(fibW2)
distFibW3Atr = f_distAtr(fibW3)
distFibY1Atr = f_distAtr(fibY1)
distFibY2Atr = f_distAtr(fibY2)
distFibY3Atr = f_distAtr(fibY3)
distFibG1Atr = f_distAtr(fibG1)
distFibG2Atr = f_distAtr(fibG2)
distFibG3Atr = f_distAtr(fibG3)

// -------------------------
// Auto pattern heuristics (secondary to manual pattern context)
// -------------------------
autoPatternEnabled = input.bool(true, "Auto Pattern Heuristics")
pivotLen = input.int(4, "Pattern Pivot Length", minval=2)
impulseLen = input.int(12, "Pattern Impulse Length", minval=5)
consLen = input.int(10, "Pattern Consolidation Length", minval=5)
impulseAtrMin = input.float(1.8, "Pattern Impulse ATR Min", minval=0.5, step=0.1)
flagMaxRangeAtr = input.float(3.2, "Flag Max Consolidation ATR", minval=1.0, step=0.1)
pennantMaxRangeAtr = input.float(2.8, "Pennant Max Consolidation ATR", minval=0.8, step=0.1)
patternMinConf = input.float(0.60, "Pattern Min Confidence", minval=0.4, maxval=0.9, step=0.05)
compressionBars = input.int(12, "Compression Bars", minval=4)
compressionRatioMax = input.float(0.75, "Compression Ratio Max", minval=0.2, maxval=1.0, step=0.05)

ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

ph0 = ta.valuewhen(not na(ph), ph, 0)
ph1 = ta.valuewhen(not na(ph), ph, 1)
ph2 = ta.valuewhen(not na(ph), ph, 2)
phBar0 = ta.valuewhen(not na(ph), bar_index - pivotLen, 0)
phBar1 = ta.valuewhen(not na(ph), bar_index - pivotLen, 1)
phBar2 = ta.valuewhen(not na(ph), bar_index - pivotLen, 2)

pl0 = ta.valuewhen(not na(pl), pl, 0)
pl1 = ta.valuewhen(not na(pl), pl, 1)
plBar0 = ta.valuewhen(not na(pl), bar_index - pivotLen, 0)
plBar1 = ta.valuewhen(not na(pl), bar_index - pivotLen, 1)

consHigh = ta.highest(high, consLen)
consLow = ta.lowest(low, consLen)
consRange = consHigh - consLow
consRangeAtr = atr14 > 0 ? consRange / atr14 : na
consRangePrev = ta.highest(high[consLen], consLen) - ta.lowest(low[consLen], consLen)
consContracting = consRangePrev > 0 ? consRange < consRangePrev : false
slopeHigh = ta.linreg(high, consLen, 0) - ta.linreg(high, consLen, 1)
slopeLow = ta.linreg(low, consLen, 0) - ta.linreg(low, consLen, 1)
compressionRangeNow = ta.highest(high, compressionBars) - ta.lowest(low, compressionBars)
compressionRangePrev = ta.highest(high[compressionBars], compressionBars) - ta.lowest(low[compressionBars], compressionBars)
compressionRatio = compressionRangePrev > 0 ? compressionRangeNow / compressionRangePrev : 1.0
isCompression = compressionRatio <= compressionRatioMax

poleLookback = impulseLen + consLen
poleHigh = ta.highest(high, poleLookback)
poleLow = ta.lowest(low, poleLookback)
poleSizeAtr = atr14 > 0 ? (poleHigh - poleLow) / atr14 : 0.0
recentDownBias = close < emaSlow or emaBearStack
recentUpBias = close > emaSlow or emaBullStack
impulseDown = poleSizeAtr >= impulseAtrMin and recentDownBias and close <= close[consLen]
impulseUp = poleSizeAtr >= impulseAtrMin and recentUpBias and close >= close[consLen]
priorUptrend = recentUpBias
priorDowntrend = recentDownBias

bf1 = impulseDown or priorDowntrend
bf2 = consRangeAtr <= flagMaxRangeAtr
bf3 = slopeHigh > 0 and slopeLow > 0
bf4 = math.abs(slopeHigh - slopeLow) <= atr14 * 0.05
bearFlagConf = (bf1 ? 1.0 : 0.0) + (bf2 ? 1.0 : 0.0) + (bf3 ? 1.0 : 0.0) + (bf4 ? 1.0 : 0.0)
bearFlagConf := bearFlagConf / 4.0
bearFlag = autoPatternEnabled and bearFlagConf >= patternMinConf and recentDownBias
bearFlagBreak = bearFlag and close < consLow[1]

buf1 = impulseUp or priorUptrend
buf2 = consRangeAtr <= flagMaxRangeAtr
buf3 = slopeHigh < 0 and slopeLow < 0
buf4 = math.abs(slopeHigh - slopeLow) <= atr14 * 0.05
bullFlagConf = (buf1 ? 1.0 : 0.0) + (buf2 ? 1.0 : 0.0) + (buf3 ? 1.0 : 0.0) + (buf4 ? 1.0 : 0.0)
bullFlagConf := bullFlagConf / 4.0
bullFlag = autoPatternEnabled and bullFlagConf >= patternMinConf and recentUpBias
bullFlagBreak = bullFlag and close > consHigh[1]

bp1 = impulseDown or priorDowntrend
bp2 = consRangeAtr <= pennantMaxRangeAtr
bp3 = slopeHigh < 0 and slopeLow > 0
bp4 = consContracting
bp5 = isCompression
bearPennantConf = (bp1 ? 1.0 : 0.0) + (bp2 ? 1.0 : 0.0) + (bp3 ? 1.0 : 0.0) + (bp4 ? 1.0 : 0.0) + (bp5 ? 1.0 : 0.0)
bearPennantConf := bearPennantConf / 5.0
bearPennant = autoPatternEnabled and bearPennantConf >= patternMinConf and recentDownBias
bearPennantBreak = bearPennant and close < consLow[1]

bup1 = impulseUp or priorUptrend
bup2 = consRangeAtr <= pennantMaxRangeAtr
bup3 = slopeHigh < 0 and slopeLow > 0
bup4 = consContracting
bup5 = isCompression
bullPennantConf = (bup1 ? 1.0 : 0.0) + (bup2 ? 1.0 : 0.0) + (bup3 ? 1.0 : 0.0) + (bup4 ? 1.0 : 0.0) + (bup5 ? 1.0 : 0.0)
bullPennantConf := bullPennantConf / 5.0
bullPennant = autoPatternEnabled and bullPennantConf >= patternMinConf and recentUpBias
bullPennantBreak = bullPennant and close > consHigh[1]

dtOrder = not na(phBar0) and not na(phBar1) and not na(plBar0) and plBar0 > phBar1 and plBar0 < phBar0
dtPeaks = not na(ph0) and not na(ph1) and math.abs(ph0 - ph1) <= atr14 * 0.8
dtDip = not na(pl0) and not na(ph0) and not na(ph1) and (math.min(ph0, ph1) - pl0) >= atr14 * 1.0
dtSep = not na(phBar0) and not na(phBar1) and math.abs(phBar0 - phBar1) >= pivotLen * 3
dtTrend = priorUptrend and close > emaSlow and emaFast > emaSlow
doubleTopConf = (dtOrder ? 1.0 : 0.0) + (dtPeaks ? 1.0 : 0.0) + (dtDip ? 1.0 : 0.0) + (dtSep ? 1.0 : 0.0) + (dtTrend ? 1.0 : 0.0)
doubleTopConf := doubleTopConf / 5.0
doubleTop = autoPatternEnabled and doubleTopConf >= 0.75 and dtTrend
doubleTopBreak = doubleTop and close < pl0

hsOrder = not na(phBar2) and not na(plBar1) and not na(phBar1) and not na(plBar0) and not na(phBar0) and phBar2 < plBar1 and plBar1 < phBar1 and phBar1 < plBar0 and plBar0 < phBar0
hsShoulders = not na(ph2) and not na(ph0) and math.abs(ph2 - ph0) <= atr14 * 1.0
hsHead = not na(ph1) and not na(ph2) and not na(ph0) and ph1 > ph2 + atr14 * 0.7 and ph1 > ph0 + atr14 * 0.7
hsNeck = not na(pl1) and not na(pl0) ? (pl1 + pl0) / 2.0 : na
hsConf = (hsOrder ? 1.0 : 0.0) + (hsShoulders ? 1.0 : 0.0) + (hsHead ? 1.0 : 0.0)
hsConf := hsConf / 3.0
headShoulders = autoPatternEnabled and hsConf >= 0.67
headShouldersBreak = headShoulders and not na(hsNeck) and close < hsNeck

chOrder = not na(phBar2) and not na(plBar1) and not na(phBar0) and not na(plBar0) and phBar2 < plBar1 and plBar1 < phBar0 and phBar0 < plBar0
chRim = not na(ph2) and not na(ph0) and math.abs(ph2 - ph0) <= atr14 * 1.2
chDepth = not na(pl1) and not na(ph2) and not na(ph0) and (math.min(ph2, ph0) - pl1) >= atr14 * 1.5
chHandle = not na(pl0) and not na(ph0) and not na(pl1) and (ph0 - pl0) <= (math.min(ph2, ph0) - pl1) * 0.5
cupHandleConf = (chOrder ? 1.0 : 0.0) + (chRim ? 1.0 : 0.0) + (chDepth ? 1.0 : 0.0) + (chHandle ? 1.0 : 0.0)
cupHandleConf := cupHandleConf / 4.0
cupHandle = autoPatternEnabled and cupHandleConf >= 0.75
cupHandleBreak = cupHandle and close > math.max(ph2, ph0)

autoPattern = "none"
autoPatternBias = "neutral"
autoPatternConf = 0.0
autoPatternTrigger = false

if bearFlag and bearFlagConf > autoPatternConf
    autoPattern := "bear_flag"
    autoPatternBias := "bearish"
    autoPatternConf := bearFlagConf
    autoPatternTrigger := bearFlagBreak
if bullFlag and bullFlagConf > autoPatternConf
    autoPattern := "bull_flag"
    autoPatternBias := "bullish"
    autoPatternConf := bullFlagConf
    autoPatternTrigger := bullFlagBreak
if bearPennant and bearPennantConf > autoPatternConf
    autoPattern := "bear_pennant"
    autoPatternBias := "bearish"
    autoPatternConf := bearPennantConf
    autoPatternTrigger := bearPennantBreak
if bullPennant and bullPennantConf > autoPatternConf
    autoPattern := "bull_pennant"
    autoPatternBias := "bullish"
    autoPatternConf := bullPennantConf
    autoPatternTrigger := bullPennantBreak
if doubleTop and doubleTopConf > autoPatternConf
    autoPattern := "double_top"
    autoPatternBias := "bearish"
    autoPatternConf := doubleTopConf
    autoPatternTrigger := doubleTopBreak
if headShoulders and hsConf > autoPatternConf
    autoPattern := "head_shoulders"
    autoPatternBias := "bearish"
    autoPatternConf := hsConf
    autoPatternTrigger := headShouldersBreak
if cupHandle and cupHandleConf > autoPatternConf
    autoPattern := "cup_handle"
    autoPatternBias := "bullish"
    autoPatternConf := cupHandleConf
    autoPatternTrigger := cupHandleBreak

autoPatternStrong = autoPatternEnabled and autoPatternConf >= 0.70
autoPatternAligned = (patternBias == "bullish" and autoPatternBias == "bullish") or (patternBias == "bearish" and autoPatternBias == "bearish")
autoPatternOverruledByManual = autoPatternStrong and patternConfirmed and patternBias != "neutral" and not autoPatternAligned

// -------------------------
// Confluence scoring aligned to your priority order
// Pattern > Fib > Levels > MACD/TTM > RSI
// Directional: score separately for bull/bear, pick active side based on tradeDirection
// -------------------------
score = 0

// Pattern first
score += patternConfirmed ? 4 : 0
score += patternBias == "bullish" ? 1 : patternBias == "bearish" ? -1 : 0

// Fib second
score += fibWeight

// Levels third
score += (atHighLevel or atLowLevel or breakAboveLevel or breakBelowLevel) ? 2 : 0

// MACD + squeeze fourth
score += macdBullExpand ? 1 : 0
score -= macdBearExpand ? 1 : 0
score += squeezeRelease ? 1 : 0

// RSI fifth
score += rsiBullRegime ? 1 : 0
score -= rsiBearRegime ? 1 : 0
score += rsiCrossUp50 ? 1 : 0
score -= rsiCrossDown50 ? 1 : 0

// EMA / SRChannel are context enhancers
score += emaBullStack ? 1 : 0
score -= emaBearStack ? 1 : 0
score += emaCompressed ? 1 : 0
score += (nearSrUpper or nearSrLower) ? 1 : 0

// Trade-level alignment enhancer
score += nearEntry ? 1 : 0
score += autoPatternStrong ? 1 : 0
score += autoPatternStrong and autoPatternAligned ? 1 : 0
score += autoPatternTrigger ? 1 : 0

// -------------------------
// Directional confluence: score independently for each side
// Agent uses activeScore (aligned to tradeDirection) for final classification
// -------------------------
bullScore = 0
bullScore += patternConfirmed and patternBias == "bullish" ? 5 : 0
bullScore += patternBias == "bullish" ? 1 : 0
bullScore += fibWeight
bullScore += (breakAboveLevel or atLowLevel) ? 2 : 0
bullScore += macdBullExpand ? 1 : 0
bullScore += squeezeRelease ? 1 : 0
bullScore += rsiBullRegime ? 1 : 0
bullScore += rsiCrossUp50 ? 1 : 0
bullScore += emaBullStack ? 2 : 0
bullScore += emaCompressed ? 1 : 0
bullScore += nearSrLower ? 1 : 0
bullScore += nearEntry and tradeDirection == "long" ? 1 : 0
bullScore += autoPatternStrong and autoPatternBias == "bullish" ? 2 : 0
bullScore += autoPatternTrigger and autoPatternBias == "bullish" ? 1 : 0

bearScore = 0
bearScore += patternConfirmed and patternBias == "bearish" ? 5 : 0
bearScore += patternBias == "bearish" ? 1 : 0
bearScore += fibWeight
bearScore += (breakBelowLevel or atHighLevel) ? 2 : 0
bearScore += macdBearExpand ? 1 : 0
bearScore += squeezeRelease ? 1 : 0
bearScore += rsiBearRegime ? 1 : 0
bearScore += rsiCrossDown50 ? 1 : 0
bearScore += emaBearStack ? 2 : 0
bearScore += emaCompressed ? 1 : 0
bearScore += nearSrUpper ? 1 : 0
bearScore += nearEntry and tradeDirection == "short" ? 1 : 0
bearScore += autoPatternStrong and autoPatternBias == "bearish" ? 2 : 0
bearScore += autoPatternTrigger and autoPatternBias == "bearish" ? 1 : 0

activeScore = tradeDirection == "long" ? bullScore : bearScore
oppositeScore = tradeDirection == "long" ? bearScore : bullScore

confluenceClass = activeScore >= 8 ? "HIGH" : activeScore >= 4 ? "MEDIUM" : "LOW"
bias = score > 1 ? "BULLISH" : score < -1 ? "BEARISH" : "NEUTRAL"

// Best R:R across all TP levels (for quick agent sanity check)
bestRR = math.max(na(rrTp1) ? 0.0 : rrTp1, na(rrTp2) ? 0.0 : rrTp2, na(rrTp3) ? 0.0 : rrTp3)

// -------------------------
// Visual status label
// -------------------------
var label statusLabel = na
if barstate.islast
    label.delete(statusLabel)
    statusText = "Pattern: " + patternBias + " (" + str.tostring(patternConfirmed) + ")" +
      "\nFib: " + fibSignificance +
      "\nMACD: " + (macdBullExpand ? "bull expand" : macdBearExpand ? "bear expand" : "flat") +
      "\nSqueezeRelease: " + str.tostring(squeezeRelease) +
      "\nRSI: " + str.tostring(rsi, format.mintick) +
      "\nAutoPattern: " + autoPattern + " (" + str.tostring(autoPatternConf, format.mintick) + ")" +
      "\nEntryNear: " + str.tostring(nearEntry) +
      "\nBullScore: " + str.tostring(bullScore) + " | BearScore: " + str.tostring(bearScore) +
      "\nActiveScore (" + tradeDirection + "): " + str.tostring(activeScore) + " (" + confluenceClass + ")" +
      "\nRawScore: " + str.tostring(score) + " | BestRR: " + str.tostring(bestRR, "#.##") +
      "\nBias: " + bias
    statusLabel := label.new(bar_index, high, statusText, style=label.style_label_down, color=color.new(color.black, 0), textcolor=color.white)

// -------------------------
// Webhook payload
// -------------------------
symbolText = syminfo.ticker
tfText = timeframe.period
barTime = str.tostring(time)

payload = "{"
payload += "\"symbol\":\"" + symbolText + "\""
payload += ",\"timeframe\":\"" + tfText + "\""
payload += ",\"bar_time\":\"" + barTime + "\""
payload += ",\"taxonomy_version\":\"" + taxonomyVersion + "\""
payload += ",\"setup_id\":\"" + setupId + "\""
payload += ",\"pattern_type\":\"" + patternType + "\""
payload += ",\"setup_stage\":\"" + setupStage + "\""
payload += ",\"time_horizon\":\"" + timeHorizon + "\""
payload += ",\"close\":" + str.tostring(close)
payload += ",\"open\":" + str.tostring(open)
payload += ",\"high\":" + str.tostring(high)
payload += ",\"low\":" + str.tostring(low)
payload += ",\"bar_range\":" + str.tostring(barRange)
payload += ",\"bar_body\":" + str.tostring(barBody)
payload += ",\"body_pct_of_range\":" + str.tostring(bodyPctOfRange)
payload += ",\"upper_wick_pct\":" + str.tostring(upperWickPct)
payload += ",\"lower_wick_pct\":" + str.tostring(lowerWickPct)
payload += ",\"range_atr_ratio\":" + str.tostring(rangeAtrRatio)
payload += ",\"atr14\":" + str.tostring(atr14)
payload += ",\"use_trade_levels\":" + str.tostring(useTradeLevels)
payload += ",\"trade_direction\":\"" + tradeDirection + "\""
payload += ",\"entry_price\":" + str.tostring(entryPrice)
payload += ",\"stop_price\":" + str.tostring(stopPrice)
payload += ",\"tp1_price\":" + str.tostring(tp1Price)
payload += ",\"tp2_price\":" + str.tostring(tp2Price)
payload += ",\"tp3_price\":" + str.tostring(tp3Price)
payload += ",\"near_entry\":" + str.tostring(nearEntry)
payload += ",\"near_stop\":" + str.tostring(nearStop)
payload += ",\"near_tp1\":" + str.tostring(nearTp1)
payload += ",\"near_tp2\":" + str.tostring(nearTp2)
payload += ",\"near_tp3\":" + str.tostring(nearTp3)
payload += ",\"hit_entry\":" + str.tostring(hitEntry)
payload += ",\"hit_stop\":" + str.tostring(hitStop)
payload += ",\"hit_tp1\":" + str.tostring(hitTp1)
payload += ",\"hit_tp2\":" + str.tostring(hitTp2)
payload += ",\"hit_tp3\":" + str.tostring(hitTp3)
payload += ",\"hit_entry_close\":" + str.tostring(hitEntryClose)
payload += ",\"hit_stop_close\":" + str.tostring(hitStopClose)
payload += ",\"hit_tp1_close\":" + str.tostring(hitTp1Close)
payload += ",\"hit_tp2_close\":" + str.tostring(hitTp2Close)
payload += ",\"hit_tp3_close\":" + str.tostring(hitTp3Close)
payload += ",\"dist_entry_atr\":" + str.tostring(distEntryAtr)
payload += ",\"dist_stop_atr\":" + str.tostring(distStopAtr)
payload += ",\"dist_tp1_atr\":" + str.tostring(distTp1Atr)
payload += ",\"dist_tp2_atr\":" + str.tostring(distTp2Atr)
payload += ",\"dist_tp3_atr\":" + str.tostring(distTp3Atr)
payload += ",\"rr_tp1\":" + str.tostring(rrTp1)
payload += ",\"rr_tp2\":" + str.tostring(rrTp2)
payload += ",\"rr_tp3\":" + str.tostring(rrTp3)
payload += ",\"best_rr\":" + str.tostring(bestRR)
payload += ",\"bull_score\":" + str.tostring(bullScore)
payload += ",\"bear_score\":" + str.tostring(bearScore)
payload += ",\"active_score\":" + str.tostring(activeScore)
payload += ",\"opposite_score\":" + str.tostring(oppositeScore)
payload += ",\"pattern_bias\":\"" + patternBias + "\""
payload += ",\"pattern_confirmed\":" + str.tostring(patternConfirmed)
payload += ",\"auto_pattern\":\"" + autoPattern + "\""
payload += ",\"auto_pattern_bias\":\"" + autoPatternBias + "\""
payload += ",\"auto_pattern_conf\":" + str.tostring(autoPatternConf)
payload += ",\"auto_pattern_strong\":" + str.tostring(autoPatternStrong)
payload += ",\"auto_pattern_trigger\":" + str.tostring(autoPatternTrigger)
payload += ",\"auto_pattern_aligned\":" + str.tostring(autoPatternAligned)
payload += ",\"auto_pattern_overruled_by_manual\":" + str.tostring(autoPatternOverruledByManual)
payload += ",\"compression_ratio\":" + str.tostring(compressionRatio)
payload += ",\"is_compression\":" + str.tostring(isCompression)
payload += ",\"auto_bear_flag\":" + str.tostring(bearFlag)
payload += ",\"auto_bull_flag\":" + str.tostring(bullFlag)
payload += ",\"auto_bear_pennant\":" + str.tostring(bearPennant)
payload += ",\"auto_bull_pennant\":" + str.tostring(bullPennant)
payload += ",\"auto_head_shoulders\":" + str.tostring(headShoulders)
payload += ",\"auto_double_top\":" + str.tostring(doubleTop)
payload += ",\"auto_cup_handle\":" + str.tostring(cupHandle)
payload += ",\"fib_significance\":\"" + fibSignificance + "\""
payload += ",\"near_fib_white\":" + str.tostring(nearWhite)
payload += ",\"near_fib_yellow\":" + str.tostring(nearYellow)
payload += ",\"near_fib_green\":" + str.tostring(nearGreen)
payload += ",\"dist_fib_w1_atr\":" + str.tostring(distFibW1Atr)
payload += ",\"dist_fib_w2_atr\":" + str.tostring(distFibW2Atr)
payload += ",\"dist_fib_w3_atr\":" + str.tostring(distFibW3Atr)
payload += ",\"dist_fib_y1_atr\":" + str.tostring(distFibY1Atr)
payload += ",\"dist_fib_y2_atr\":" + str.tostring(distFibY2Atr)
payload += ",\"dist_fib_y3_atr\":" + str.tostring(distFibY3Atr)
payload += ",\"dist_fib_g1_atr\":" + str.tostring(distFibG1Atr)
payload += ",\"dist_fib_g2_atr\":" + str.tostring(distFibG2Atr)
payload += ",\"dist_fib_g3_atr\":" + str.tostring(distFibG3Atr)
payload += ",\"at_key_level_high\":" + str.tostring(atHighLevel)
payload += ",\"at_key_level_low\":" + str.tostring(atLowLevel)
payload += ",\"break_above_level\":" + str.tostring(breakAboveLevel)
payload += ",\"break_below_level\":" + str.tostring(breakBelowLevel)
payload += ",\"dist_key_high_atr\":" + str.tostring(distToHighLevelAtr)
payload += ",\"dist_key_low_atr\":" + str.tostring(distToLowLevelAtr)
payload += ",\"macd_hist\":" + str.tostring(macdHist)
payload += ",\"macd_bull_expand\":" + str.tostring(macdBullExpand)
payload += ",\"macd_bear_expand\":" + str.tostring(macdBearExpand)
payload += ",\"macd_hist_slope3\":" + str.tostring(macdHistSlope3)
payload += ",\"macd_line\":" + str.tostring(macdLine)
payload += ",\"macd_signal\":" + str.tostring(signalLine)
payload += ",\"squeeze_on\":" + str.tostring(squeezeOn)
payload += ",\"squeeze_release\":" + str.tostring(squeezeRelease)
payload += ",\"rsi\":" + str.tostring(rsi)
payload += ",\"rsi_bull_regime\":" + str.tostring(rsiBullRegime)
payload += ",\"rsi_bear_regime\":" + str.tostring(rsiBearRegime)
payload += ",\"rsi_slope3\":" + str.tostring(rsiSlope3)
payload += ",\"ema_bull_stack\":" + str.tostring(emaBullStack)
payload += ",\"ema_bear_stack\":" + str.tostring(emaBearStack)
payload += ",\"ema_compressed\":" + str.tostring(emaCompressed)
payload += ",\"ema_fast\":" + str.tostring(emaFast)
payload += ",\"ema_mid1\":" + str.tostring(emaMid1)
payload += ",\"ema_mid2\":" + str.tostring(emaMid2)
payload += ",\"ema_slow\":" + str.tostring(emaSlow)
payload += ",\"ema_spread_atr\":" + str.tostring(emaSpreadAtr)
payload += ",\"dist_ema_fast_atr\":" + str.tostring(distToEmaFastAtr)
payload += ",\"dist_ema_slow_atr\":" + str.tostring(distToEmaSlowAtr)
payload += ",\"sr_near_upper\":" + str.tostring(nearSrUpper)
payload += ",\"sr_near_lower\":" + str.tostring(nearSrLower)
payload += ",\"score\":" + str.tostring(score)
payload += ",\"confluence\":\"" + confluenceClass + "\""
payload += ",\"bias\":\"" + bias + "\""
payload += "}"

// Alert trigger options
emitOnClose = input.bool(true, "Emit Alert On Every Bar Close")
emitOnlyOnSignal = input.bool(false, "Emit Only On Medium/High Confluence")
signalFire = emitOnlyOnSignal ? (confluenceClass != "LOW") : true

if barstate.isconfirmed and emitOnClose and signalFire
    alert(payload, alert.freq_once_per_bar_close)

alertcondition(barstate.isconfirmed and signalFire, "Confluence Payload", "Confluence payload is ready for webhook.")
alertcondition(barstate.isconfirmed and hitEntry, "Entry Hit", "Price touched manual entry level (wick).")
alertcondition(barstate.isconfirmed and hitEntryClose, "Entry Hit (Close Confirmed)", "Price closed at manual entry level.")
alertcondition(barstate.isconfirmed and hitStop, "Stop Hit", "Price touched manual stop level (wick).")
alertcondition(barstate.isconfirmed and hitStopClose, "Stop Hit (Close Confirmed)", "Price closed at manual stop level.")
alertcondition(barstate.isconfirmed and hitTp1, "TP1 Hit", "Price touched manual TP1 level.")
alertcondition(barstate.isconfirmed and hitTp2, "TP2 Hit", "Price touched manual TP2 level.")
alertcondition(barstate.isconfirmed and hitTp3, "TP3 Hit", "Price touched manual TP3 level.")
alertcondition(barstate.isconfirmed and nearEntry and confluenceClass != "LOW", "Near Entry With Confluence", "Price is near entry with medium/high confluence.")
alertcondition(barstate.isconfirmed and bearFlagBreak, "Bear Flag Breakdown", "Auto bear flag breakdown trigger.")
alertcondition(barstate.isconfirmed and bullFlagBreak, "Bull Flag Breakout", "Auto bull flag breakout trigger.")
alertcondition(barstate.isconfirmed and bearPennantBreak, "Bear Pennant Breakdown", "Auto bear pennant breakdown trigger.")
alertcondition(barstate.isconfirmed and bullPennantBreak, "Bull Pennant Breakout", "Auto bull pennant breakout trigger.")
alertcondition(barstate.isconfirmed and doubleTopBreak, "Double Top Breakdown", "Auto double top breakdown trigger.")
alertcondition(barstate.isconfirmed and headShouldersBreak, "Head and Shoulders Breakdown", "Auto head and shoulders breakdown trigger.")
alertcondition(barstate.isconfirmed and cupHandleBreak, "Cup and Handle Breakout", "Auto cup and handle breakout trigger.")
